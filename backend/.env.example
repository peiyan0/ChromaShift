# --- Supabase (Primary Architecture) ---
# Project Ref & URL
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=${SUPABASE_URL}

# --- Public (Frontend/Client) ---
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# --- Backend (Server/Edge Functions) ---
# JWT Secret (Backend validation)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Secret/Service Role Keys for administrative tasks
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_SECRET_KEY=your-supabase-secret-key

# --- Database ---
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_S3_REGION=your-project-region
DB_PASSWORD=your-secure-password
# Direct connection
DATABASE_DIRECT_URL=postgresql://postgres:[your-project-ref]@db.[your-secure-password].supabase.co:5432/postgres
# Shared pooler session mode 
DATABASE_SESSION_URL=postgresql://postgres.[your-secure-password]:[your-project-ref]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# Shared pooler transaction mode 
DATABASE_TRANSACTION_URL=postgresql://postgres.[your-secure-password]:[your-project-ref]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Storage / S3 API Credentials (Backend usage only)
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key

# --- Local Fallback: Services ---
# PostGres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=antigravity
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (Local Storage)
MINIO_SERVER=localhost:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_BUCKET_NAME=cvd-media

# --- Backend Security & API ---
# Generate a new random string for production
SECRET_KEY=replace_me_with_a_secure_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENABLE_OPENAPI=false

# Frontend API Endpoint
VITE_API_URL=http://localhost:8000/api/v1

# --- Hugging Face ---
HF_TOKEN=your_hugging_face_token